# Hardcover API token — https://hardcover.app/account/api
# Required for every command that writes to (or reads from) Hardcover.
# Tokens expire every January 1; rotate then.
HARDCOVER_API_TOKEN=

# Optional Discord webhook for notifications (added editions, review-queue
# items, errors). Leave empty to disable notifications entirely.
DISCORD_WEBHOOK_URL=

# Where the local sqlite state lives (catalog cache, processed log, review
# queue). In Docker this should point inside the mounted volume.
STATE_DB_PATH=data/se_hardcover.sqlite3

# Daemon poll interval in seconds (default 1 hour). The new-releases feed holds
# 15 entries, so even daily polling cannot miss a release.
POLL_INTERVAL=3600

# How often the daemon runs the reconcile audit (data accuracy + coverage), in
# seconds. 0 = every poll cycle. Raise it (e.g. 86400 for daily) if you want the
# audit — and its cover-image downloads — to run less often than the feed check.
AUDIT_INTERVAL=0

# Whether the reconcile audit compares cover images (extra downloads per edition).
AUDIT_CHECK_COVERS=true

# Global write guard. Set to true to run any command without sending mutations.
DRY_RUN=false

# File the daemon touches each successful cycle (used by the container healthcheck).
HEARTBEAT_PATH=data/heartbeat
